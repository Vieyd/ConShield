{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "ExternalEventIngestion": {
    "Enabled": false,
    "ApiKey": "",
    "MaxRequestBodyBytes": 32768,
    "AllowedFutureClockSkewMinutes": 5
  },
  "SecurityEventOutbox": {
    "Enabled": true,
    "PollIntervalMilliseconds": 1000,
    "BatchSize": 20,
    "LockSeconds": 30,
    "MaxAttempts": 5,
    "BaseRetrySeconds": 1,
    "MaxRetrySeconds": 60,
    "JsonlRelativePath": "logs/security-events.jsonl",
    "DegradedPendingAgeSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
