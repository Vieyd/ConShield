{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=conshield;Username=conshield;Password=CHANGE_ME"
  },
  "ExternalEventIngestion": {
    "Enabled": true,
    "ApiKey": "CHANGE_ME",
    "MaxRequestBodyBytes": 32768,
    "AllowedFutureClockSkewMinutes": 5
  },
  "SecurityEventOutbox": {
    "Enabled": true,
    "Transport": "Jsonl",
    "PollIntervalMilliseconds": 1000,
    "BatchSize": 20,
    "LockSeconds": 30,
    "MaxAttempts": 5,
    "BaseRetrySeconds": 1,
    "MaxRetrySeconds": 60,
    "JsonlRelativePath": "logs/security-events.jsonl",
    "DegradedPendingAgeSeconds": 300
  },
  "RabbitMq": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/conshield",
    "UserName": "",
    "Password": "",
    "ExchangeName": "conshield.security.events.v1",
    "RoutingKey": "security.event.created",
    "QueueName": "conshield.security-events.consumer.v1",
    "DeadLetterExchangeName": "conshield.security.events.dlx.v1",
    "DeadLetterRoutingKey": "security.event.dead",
    "DeadLetterQueueName": "conshield.security-events.dead.v1",
    "PrefetchCount": 20,
    "ConnectionTimeoutSeconds": 10,
    "PublishTimeoutSeconds": 10,
    "ConsumerShutdownTimeoutSeconds": 10,
    "UseTls": false
  },
  "MongoProjection": {
    "Enabled": false,
    "ConnectionString": "",
    "DatabaseName": "conshield_events",
    "CollectionName": "security_event_raw_v1",
    "RetentionDays": 30,
    "ConnectTimeoutSeconds": 10,
    "OperationTimeoutSeconds": 10,
    "MaxDocumentBytes": 262144
  },
  "DeadLetterReplay": {
    "Enabled": true,
    "MaxReplayRequestsPerMessage": 3,
    "MinimumIntervalSeconds": 60,
    "MaxMessageAgeDays": 30,
    "BatchSize": 10,
    "LockSeconds": 30,
    "MaxPublishAttempts": 5,
    "BaseRetrySeconds": 2,
    "MaxRetrySeconds": 60,
    "MaxReasonLength": 500,
    "MaxPayloadBytes": 262144,
    "PollIntervalMilliseconds": 1000
  },
  "DemoUsers": [
    {
      "UserName": "adminib",
      "Password": "change-this-admin-password",
      "DisplayName": "Администратор ИБ",
      "Role": "AdminIB"
    },
    {
      "UserName": "operator",
      "Password": "change-this-operator-password",
      "DisplayName": "Оператор",
      "Role": "Operator"
    }
  ]
}
