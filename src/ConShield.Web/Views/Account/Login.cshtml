@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header app-login-card-header">
                <span>Вход в ConShield</span>
                <button class="app-theme-toggle app-theme-toggle-login"
                        type="button"
                        data-theme-toggle
                        aria-label="Переключить тему"
                        aria-pressed="false">
                    <span aria-hidden="true">◐</span>
                    <span>Тема: <span data-theme-label>Светлая</span></span>
                </button>
            </div>
            <div class="card-body">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" autocomplete="username" placeholder="Введите логин" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Введите пароль" data-password-input />
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    data-password-toggle
                                    aria-controls="Password"
                                    aria-pressed="false"
                                    aria-label="Показать пароль">
                                Показать
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary">Войти</button>
                </form>

                <hr />
                <div class="small text-muted">
                    Доступ в систему предоставляется в соответствии с назначенной ролью пользователя.
                </div>
            </div>
        </div>
    </div>
</div>
