@using ConShield.Contracts.Enums
@using ConShield.Web.Infrastructure
@using ConShield.Web.ViewModels
@model ConShield.Web.ViewModels.SecuritySummaryReportViewModel
@{
    ViewData["Title"] = "Сводка безопасности";
}

<div class="app-page-header">
    <div>
        <h2 class="mb-1">Сводка безопасности</h2>
        <div class="text-muted small">Отчет только для чтения для роли AdminIB на основе агрегированных данных PostgreSQL.</div>
    </div>
    <span class="app-status @DisplayText.StatusClass(Model.OverallStatus)"><span class="app-status-dot" aria-hidden="true"></span><span>@DisplayText.SecuritySummaryStatus(Model.OverallStatus)</span></span>
</div>

<div class="alert alert-info py-2">
    Отчет и экспорт содержат только счетчики и временные метки. Они не показывают raw JSON событий, учетные данные, хэши,
    API keys, переменные окружения, токены, пароли, cookies или строки подключения.
    Ежедневный workflow описан в <code>docs/OPERATIONS_AND_SIEM_RUNBOOK.md</code>.
</div>

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-sm @(Model.RangeKey == "24h" ? "btn-primary" : "btn-outline-primary")"
       asp-controller="Reports" asp-action="SecuritySummary" asp-route-range="24h">24h</a>
    <a class="btn btn-sm @(Model.RangeKey == "2d" ? "btn-primary" : "btn-outline-primary")"
       asp-controller="Reports" asp-action="SecuritySummary" asp-route-range="2d">2d</a>
    <a class="btn btn-sm @(Model.RangeKey == "7d" ? "btn-primary" : "btn-outline-primary")"
       asp-controller="Reports" asp-action="SecuritySummary" asp-route-range="7d">7d</a>
    <a class="btn btn-sm btn-outline-secondary"
       asp-controller="Reports" asp-action="SecuritySummaryMarkdown" asp-route-range="@Model.RangeKey">Скачать Markdown</a>
</div>

<div class="text-muted small mb-4">
    Сформировано: @Model.GeneratedAtUtc.ToMoscowDisplay() · Диапазон: @Model.RangeLabel
    (@Model.RangeStartUtc.ToMoscowDisplay() — @Model.RangeEndUtc.ToMoscowDisplay())
</div>

<h4>Сенсоры</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Всего / активных</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Sensors.Total / @Model.Sensors.Active</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Отозваны</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Sensors.Revoked</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">В сети / предупреждение / нет связи</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Sensors.Online / @Model.Sensors.Warning / @Model.Sensors.Offline</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Последний heartbeat</div><div class="fs-5"><span class="app-badge badge-neutral">@(Model.Sensors.LatestHeartbeatAtUtc?.ToMoscowDisplay() ?? "—")</span></div></div></div></div>
</div>

<h4>События безопасности</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Событий за период</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.SecurityEvents.EventsInRange</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Последнее событие</div><div class="fs-5"><span class="app-badge badge-neutral">@(Model.SecurityEvents.LatestEventAtUtc?.ToMoscowDisplay() ?? "—")</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Lifecycle-аудит</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.SecurityEvents.LifecycleAuditEvents</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Распределение по критичности</div><div class="small">Инфо @Model.SecurityEvents.SeverityCounts.GetValueOrDefault(EventSeverity.Info), предупреждение @Model.SecurityEvents.SeverityCounts.GetValueOrDefault(EventSeverity.Warning), высокая @Model.SecurityEvents.SeverityCounts.GetValueOrDefault(EventSeverity.High), критическая @Model.SecurityEvents.SeverityCounts.GetValueOrDefault(EventSeverity.Critical)</div></div></div></div>
</div>

<h4>SIEM</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Активные оповещения</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Siem.ActiveAlerts</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Lifecycle-оповещения SIEM</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Siem.LifecycleAlertsInRange</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">LIFE-001 / LIFE-002</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Siem.Life001AlertsInRange / @Model.Siem.Life002AlertsInRange</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Инцидентов за период</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Siem.IncidentsInRange</span></div></div></div></div>
</div>

<h4>Пайплайн доставки</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Очередь: ожидает / в обработке</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Pipeline.OutboxPending / @Model.Pipeline.OutboxProcessing</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Ошибки доставки</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Pipeline.OutboxDeadLetter</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Подтверждения: всего / за период</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Pipeline.InboxTotal / @Model.Pipeline.InboxInRange</span></div></div></div></div>
    <div class="col-md-3"><div class="app-card h-100"><div class="card-body"><div class="text-muted small">Повторные доставки / delivery &gt; 1</div><div class="fs-5"><span class="app-badge badge-neutral">@Model.Pipeline.InboxRedelivered / @Model.Pipeline.InboxDeliveryCountOverOne</span></div></div></div></div>
</div>

<h4>Чек-лист оператора</h4>
<ul class="mb-4">
    @foreach (var item in Model.OperatorChecklist)
    {
        <li>@item</li>
    }
</ul>

<h4>Предпросмотр Markdown-экспорта</h4>
<textarea class="form-control app-code app-code-panel app-markdown-preview small mb-4" rows="18" readonly>@Model.Markdown</textarea>
