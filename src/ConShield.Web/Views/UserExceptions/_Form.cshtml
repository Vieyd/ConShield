@model UserExceptionEditViewModel

<form method="post">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="UserLogin" class="form-label"></label>
        <input asp-for="UserLogin" class="form-control" />
        <span asp-validation-for="UserLogin" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SourceSystem" class="form-label"></label>
        <input asp-for="SourceSystem" class="form-control" />
        <span asp-validation-for="SourceSystem" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ExceptionType" class="form-label"></label>
        <input asp-for="ExceptionType" class="form-control" />
        <span asp-validation-for="ExceptionType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="ExpiresAtLocal" class="form-label"></label>
        <input asp-for="ExpiresAtLocal" class="form-control" type="datetime-local" value="@(Model.ExpiresAtLocal?.ToString("yyyy-MM-ddTHH:mm"))" />
        <span asp-validation-for="ExpiresAtLocal" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>
