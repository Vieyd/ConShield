@model IEnumerable<UserExceptionDto>
@{
    ViewData["Title"] = "Пользовательские исключения";
}

<div class="app-page-header">
    <h2 class="mb-0">Пользовательские исключения</h2>
    @if (User.IsInRole("AdminIB"))
    {
        <a asp-action="Create" class="btn btn-primary">Создать запись</a>
    }
</div>

<div class="app-table-card">
    <div class="app-table-scroll">
        <table class="table table-striped align-middle app-table app-table-compact">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Логин</th>
                    <th>Система</th>
                    <th>Тип</th>
                    <th>Активно</th>
                    <th>Создано</th>
                    <th class="app-table-actions-col">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><code class="id-code app-id-nowrap">@item.Id</code></td>
                    <td>@item.UserLogin</td>
                    <td><code class="app-technical-code app-technical-code--truncate" title="@item.SourceSystem">@DisplayText.ShortTechnicalValue(item.SourceSystem)</code></td>
                    <td>@item.ExceptionType</td>
                    <td>
                        <span class="app-status @(item.IsActive ? "app-status-ok" : "app-status-neutral")">
                            <span class="app-status-dot" aria-hidden="true"></span>
                            <span>@(item.IsActive ? "Да" : "Нет")</span>
                        </span>
                    </td>
                    <td>@item.CreatedAtUtc.ToMoscowDisplay()</td>
                    <td class="app-table-actions-col">
                        <div class="app-action-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Открыть</a>
                            @if (User.IsInRole("AdminIB"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
