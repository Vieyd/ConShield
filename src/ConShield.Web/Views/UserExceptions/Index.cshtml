@model IEnumerable<UserExceptionDto>
@{
    ViewData["Title"] = "Пользовательские исключения";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Пользовательские исключения</h2>
    @if (User.IsInRole("AdminIB"))
    {
        <a asp-action="Create" class="btn btn-primary">Создать запись</a>
    }
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Логин</th>
            <th>Система</th>
            <th>Тип</th>
            <th>Активно</th>
            <th>Создано</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.UserLogin</td>
            <td>@item.SourceSystem</td>
            <td>@item.ExceptionType</td>
            <td>@(item.IsActive ? "Да" : "Нет")</td>
            <td>@item.CreatedAtUtc.ToMoscowDisplay()</td>
            <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Открыть</a>
                @if (User.IsInRole("AdminIB"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
