@model ConShield.Web.ViewModels.DeadLetterIndexViewModel

@{
    ViewData["Title"] = "Ошибки доставки";
}

<div class="app-page-header">
    <h1 class="mb-1">Ошибки доставки</h1>
    <div class="text-muted small">Изолированные DLQ-сообщения и статус безопасного повтора.</div>
</div>

<form method="get" class="app-filter-panel row g-2 mb-3">
    <div class="col-md-2">
        <select name="eligibility" class="form-select">
            <option value="">Доступность повтора</option>
            <option value="Eligible" selected="@(Model.Eligibility == "Eligible")">Доступно для повтора</option>
            <option value="RequiresReview" selected="@(Model.Eligibility == "RequiresReview")">Требует проверки</option>
            <option value="NotEligible" selected="@(Model.Eligibility == "NotEligible")">Недоступно для повтора</option>
        </select>
    </div>
    <div class="col-md-2">
        <input name="reason" value="@Model.Reason" class="form-control" placeholder="Причина" />
    </div>
    <div class="col-md-2">
        <input name="replayStatus" value="@Model.ReplayStatus" class="form-control" placeholder="Статус повтора" />
    </div>
    <div class="col-md-2">
        <input name="capturedFromUtc" value="@(Model.CapturedFromUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" type="datetime-local" />
    </div>
    <div class="col-md-2">
        <input name="capturedToUtc" value="@(Model.CapturedToUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" type="datetime-local" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Фильтровать</button>
    </div>
</form>

<table class="table table-sm table-striped align-middle app-table">
    <thead>
        <tr>
            <th>ID карантина</th>
            <th>ID сообщения</th>
            <th>Payload SHA-256</th>
            <th>Тип</th>
            <th>Причина</th>
            <th>Доступность повтора</th>
            <th>Получено UTC</th>
            <th>Получений</th>
            <th>Повтор</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td><code class="id-code">@item.QuarantineId</code></td>
            <td><code class="id-code">@(item.OriginalMessageId?.ToString() ?? "-")</code></td>
            <td><code class="id-code">@item.PayloadSha256</code></td>
            <td>@(item.MessageType ?? "-")</td>
            <td>@item.DeadLetterReason</td>
            <td>@DisplayText.Status(item.ReplayEligibility.ToString())</td>
            <td>@item.CapturedAtUtc.ToString("u")</td>
            <td>@item.CaptureCount</td>
            <td>@(item.LatestReplayStatus ?? "-")</td>
            <td><a asp-action="Details" asp-route-id="@item.QuarantineId">Открыть</a></td>
        </tr>
    }
    </tbody>
</table>

<nav>
    <span>Страница @Model.Page из @Model.TotalPages</span>
    @if (Model.Page > 1)
    {
        <a class="ms-3" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-eligibility="@Model.Eligibility" asp-route-reason="@Model.Reason" asp-route-replayStatus="@Model.ReplayStatus">Назад</a>
    }
    @if (Model.Page < Model.TotalPages)
    {
        <a class="ms-3" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-eligibility="@Model.Eligibility" asp-route-reason="@Model.Reason" asp-route-replayStatus="@Model.ReplayStatus">Вперед</a>
    }
</nav>
