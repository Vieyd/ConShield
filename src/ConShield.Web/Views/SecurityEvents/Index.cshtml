@using ConShield.Contracts.Enums
@using ConShield.Contracts.Constants
@using ConShield.Web.Infrastructure
@model ConShield.Web.ViewModels.SecurityEventIndexViewModel
@{
    ViewData["Title"] = "События безопасности";
}

<div class="app-page-header">
    <h2 class="mb-0">События безопасности</h2>
    @if (User.IsInRole(AppRoles.AdminIB))
    {
        <div class="app-actions">
            <a class="btn btn-outline-secondary" href="/api/security-events/recent" target="_blank">JSON API</a>
        </div>
    }
</div>

<div class="app-actions mb-3">
    <a class="btn btn-sm btn-outline-info"
       asp-controller="SecurityEvents"
       asp-action="Index"
       asp-route-SourceSystem="@SecuritySourceSystems.SensorLifecycle">Lifecycle сенсоров</a>
    <a class="btn btn-sm btn-outline-info"
       asp-controller="SecurityEvents"
       asp-action="Index"
       asp-route-SourceSystem="@SecuritySourceSystems.SensorLifecycle"
       asp-route-ExternalEventType="@SensorLifecycleEventTypes.SensorCredentialRotated">Ротации</a>
    <a class="btn btn-sm btn-outline-info"
       asp-controller="SecurityEvents"
       asp-action="Index"
       asp-route-SourceSystem="@SecuritySourceSystems.SensorLifecycle"
        asp-route-ExternalEventType="@SensorLifecycleEventTypes.SensorCredentialRevoked">Отзыв учетных данных</a>
    <a class="btn btn-sm btn-outline-info"
       asp-controller="SecurityEvents"
       asp-action="Index"
       asp-route-SourceSystem="@SecuritySourceSystems.SensorLifecycle"
       asp-route-ExternalEventType="@SensorLifecycleEventTypes.SensorRevoked">Отзыв сенсоров</a>
</div>

<div class="alert alert-secondary py-2 mb-3 small">
    Lifecycle-аудит сенсоров приходит из <code>@SecuritySourceSystems.SensorLifecycle</code>:
    <code>@SensorLifecycleEventTypes.SensorCredentialRotated</code>,
    <code>@SensorLifecycleEventTypes.SensorCredentialRevoked</code>,
    <code>@SensorLifecycleEventTypes.SensorRevoked</code>.
    См. <code>docs/SENSOR_LIFECYCLE_AUDIT_PLAYBOOK.md</code> и <code>docs/OPERATIONS_AND_SIEM_RUNBOOK.md</code> в репозитории;
    не вставляйте учетные данные, API keys или значения окружения в заметки расследования.
</div>

<form method="get" class="app-filter-panel row g-2 mb-4">
    <div class="col-md-3">
        <input name="UserName" value="@Model.Filter.UserName" class="form-control" placeholder="Пользователь" />
    </div>
    <div class="col-md-3">
        <select name="Severity" class="form-select">
            <option value="">Все уровни</option>
            @foreach (EventSeverity severity in Enum.GetValues<EventSeverity>())
            {
                if (Model.Filter.Severity == severity)
                {
                    <option value="@severity" selected>@DisplayText.Severity(severity)</option>
                }
                else
                {
                    <option value="@severity">@DisplayText.Severity(severity)</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="EventType" class="form-select">
            <option value="">Все типы</option>
            @foreach (SecurityEventType eventType in Enum.GetValues<SecurityEventType>())
            {
                if (Model.Filter.EventType == eventType)
                {
                    <option value="@eventType" selected>@DisplayText.EventType(eventType)</option>
                }
                else
                {
                    <option value="@eventType">@DisplayText.EventType(eventType)</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <input name="SearchText" value="@Model.Filter.SearchText" class="form-control" placeholder="Описание / IP / JSON / источник" />
    </div>
    <div class="col-md-4">
        <input name="SourceSystem" value="@Model.Filter.SourceSystem" class="form-control" placeholder="Источник" />
    </div>
    <div class="col-md-4">
        <input name="ExternalEventType" value="@Model.Filter.ExternalEventType" class="form-control" placeholder="Внешний тип" />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-light">Применить</button>
    </div>
</form>

<div class="app-table-card">
    <div class="app-table-scroll">
        <table class="table table-striped align-middle app-table app-table-compact">
            <thead>
            <tr>
                <th>ID</th>
                <th>Время (GMT+3)</th>
                <th>Тип</th>
                <th>Критичность</th>
                <th>Актор / источник</th>
                <th>IP</th>
                <th>Описание</th>
                @if (User.IsInRole(AppRoles.AdminIB))
                {
                    <th class="app-table-actions-col">Действия</th>
                }
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><code class="id-code app-id-nowrap">@item.Id</code></td>
                    <td>@item.OccurredAtUtc.ToMoscowDisplay()</td>
                    <td>
                        <span class="app-display-primary">@DisplayText.EventType(item.EventType)</span>
                        <span class="app-display-secondary">@item.EventType</span>
                    </td>
                    <td>
                        <span class="app-status @DisplayText.SeverityClass(item.Severity)">
                            <span class="app-status-dot" aria-hidden="true"></span>
                            <span>@DisplayText.Severity(item.Severity)</span>
                        </span>
                    </td>
                    <td class="app-source-summary">
                        <span class="app-display-primary">@(string.IsNullOrWhiteSpace(item.UserName) ? "—" : item.UserName)</span>
                        @if (!string.IsNullOrWhiteSpace(item.SourceSystem))
                        {
                            <span class="app-display-secondary">
                                источник:
                                <code class="app-technical-code app-technical-code--truncate" title="@item.SourceSystem">@DisplayText.ShortTechnicalValue(item.SourceSystem)</code>
                            </span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ExternalEventType))
                        {
                            <span class="app-display-secondary">
                                тип:
                                <code class="app-technical-code app-technical-code--truncate" title="@item.ExternalEventType">@DisplayText.ShortTechnicalValue(item.ExternalEventType)</code>
                            </span>
                        }
                    </td>
                    <td>@item.SourceIp</td>
                    <td><div class="app-table-description">@item.Description</div></td>
                    @if (User.IsInRole(AppRoles.AdminIB))
                    {
                        <td class="app-table-actions-col">
                            <div class="app-action-group">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Incidents" asp-action="CreateFromEvent" asp-route-eventId="@item.Id">Создать инцидент</a>
                            </div>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" model="Model.Paging" />
