@using ConShield.Contracts.Enums
@using ConShield.Contracts.Constants
@using ConShield.Web.Infrastructure
@model ConShield.Web.ViewModels.SecurityEventIndexViewModel
@{
    ViewData["Title"] = "События безопасности";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">События безопасности</h2>
    @if (User.IsInRole(AppRoles.AdminIB))
    {
        <a class="btn btn-outline-secondary" href="/api/security-events/recent" target="_blank">JSON API</a>
    }
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <input name="UserName" value="@Model.Filter.UserName" class="form-control" placeholder="Пользователь" />
    </div>
    <div class="col-md-3">
        <select name="Severity" class="form-select">
            <option value="">Все уровни</option>
            @foreach (EventSeverity severity in Enum.GetValues<EventSeverity>())
            {
                if (Model.Filter.Severity == severity)
                {
                    <option value="@severity" selected>@severity</option>
                }
                else
                {
                    <option value="@severity">@severity</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="EventType" class="form-select">
            <option value="">Все типы</option>
            @foreach (SecurityEventType eventType in Enum.GetValues<SecurityEventType>())
            {
                if (Model.Filter.EventType == eventType)
                {
                    <option value="@eventType" selected>@eventType</option>
                }
                else
                {
                    <option value="@eventType">@eventType</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <input name="SearchText" value="@Model.Filter.SearchText" class="form-control" placeholder="Описание / IP / JSON" />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-light">Применить</button>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead>
    <tr>
        <th>ID</th>
        <th>Время (GMT+3)</th>
        <th>Тип</th>
        <th>Критичность</th>
        <th>Пользователь</th>
        <th>IP</th>
        <th>Описание</th>
        <th>Доп. данные</th>
        @if (User.IsInRole(AppRoles.AdminIB))
        {
            <th>Действия</th>
        }
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.OccurredAtUtc.ToMoscowDisplay()</td>
            <td>@item.EventType</td>
            <td>
                @switch (item.Severity)
                {
                    case EventSeverity.Critical:
                        <span class="badge text-bg-danger">Critical</span>
                        break;
                    case EventSeverity.High:
                        <span class="badge text-bg-primary">High</span>
                        break;
                    case EventSeverity.Warning:
                        <span class="badge text-bg-warning">Warning</span>
                        break;
                    default:
                        <span class="badge text-bg-info">Info</span>
                        break;
                }
            </td>
            <td>@item.UserName</td>
            <td>@item.SourceIp</td>
            <td>@item.Description</td>
            <td><code>@item.AdditionalDataJson</code></td>
            @if (User.IsInRole(AppRoles.AdminIB))
            {
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Incidents" asp-action="CreateFromEvent" asp-route-eventId="@item.Id">Создать инцидент</a>
                </td>
            }
        </tr>
    }
    </tbody>
</table>
