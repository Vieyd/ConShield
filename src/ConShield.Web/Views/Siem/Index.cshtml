@using ConShield.Contracts.Constants
@using ConShield.Contracts.Enums
@using ConShield.Web.Infrastructure
@model ConShield.Web.ViewModels.SiemAlertIndexViewModel
@{
    ViewData["Title"] = "Оповещения SIEM";
}

<div class="app-page-header">
    <h1 class="mb-0">Оповещения SIEM</h1>
    <div class="app-actions">
        <a asp-action="Rules" class="btn btn-outline-light">Правила SIEM</a>
        @if (User.IsInRole(AppRoles.AdminIB))
        {
            <form asp-action="ResetState" method="post" onsubmit="return confirm('Очистить все SIEM-оповещения и автоматически сформированные инциденты?');">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-warning" type="submit">Очистить SIEM</button>
            </form>
            <form asp-action="GenerateScenario" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-info" type="submit">Сформировать события</button>
            </form>
            <form asp-action="RunCorrelation" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-primary" type="submit">Запустить корреляцию</button>
            </form>
        }
    </div>
</div>

@if (TempData["SiemMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}

<form method="get" class="app-filter-panel mb-3">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Статус</label>
            <select name="Status" class="form-select">
                <option value="">Все</option>
                @foreach (var status in AlertStatuses.All)
                {
                    <option value="@status" selected="@(Model.Filter.Status == status)">@DisplayText.Status(status)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Критичность</label>
            <select name="Severity" class="form-select">
                <option value="">Все</option>
                @foreach (EventSeverity severity in Enum.GetValues(typeof(EventSeverity)))
                {
                    <option value="@((int)severity)" selected="@(Model.Filter.Severity == severity)">@DisplayText.Severity(severity)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Код правила</label>
            <input name="RuleCode" value="@Model.Filter.RuleCode" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Поиск</label>
            <input name="SearchText" value="@Model.Filter.SearchText" class="form-control" placeholder="Описание / ключ / правило" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-outline-light">Применить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </div>
</form>

<div class="app-table-card">
    <div class="app-table-scroll">
    <table class="table table-striped align-middle app-table app-table-wide">
        <thead>
            <tr>
                <th>ID</th>
                <th>Создан</th>
                <th>Код правила</th>
                <th>Правило</th>
                <th>Критичность</th>
                <th>Статус</th>
                <th>ID инцидента</th>
                <th>Описание</th>
                <th class="app-table-actions-col">Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.CreatedAtUtc.ToMoscowDisplay()</td>
                <td><code class="id-code">@item.RuleCode</code></td>
                <td>@DisplayText.RuleName(item.RuleCode, item.RuleName)</td>
                <td>
                    <span class="app-status @DisplayText.SeverityClass(item.Severity)">
                        <span class="app-status-dot" aria-hidden="true"></span>
                        <span>@DisplayText.Severity(item.Severity)</span>
                    </span>
                </td>
                <td>
                    <span class="app-status @DisplayText.StatusClass(item.Status)">
                        <span class="app-status-dot" aria-hidden="true"></span>
                        <span>@DisplayText.Status(item.Status)</span>
                    </span>
                </td>
                <td>
                    @if (item.IncidentId.HasValue)
                    {
                        <a asp-controller="Incidents" asp-action="Details" asp-route-id="@item.IncidentId.Value">@item.IncidentId.Value</a>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </td>
                <td><div class="app-table-description">@DisplayText.AlertDescription(item.RuleCode, item.Description)</div></td>
                <td class="app-table-actions-col">
                    <div class="app-action-group">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Открыть</a>
                    @if (User.IsInRole(AppRoles.AdminIB))
                    {
                        <form asp-action="ChangeStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="status" value="@AlertStatuses.Acknowledged" />
                            <button class="btn btn-sm btn-outline-primary" type="submit">Подтвердить</button>
                        </form>
                        <form asp-action="ChangeStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="status" value="@AlertStatuses.Closed" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Закрыть</button>
                        </form>
                    }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
