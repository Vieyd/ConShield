@using ConShield.Application.Models
@using ConShield.Contracts.Enums
@model IReadOnlyCollection<SiemRuleDefinition>
@{
    ViewData["Title"] = "Правила SIEM";
}

<div class="app-page-header">
    <h1 class="mb-0">Правила SIEM</h1>
    <a asp-action="Index" class="btn btn-outline-light">К оповещениям</a>
</div>

<div class="alert alert-info">
    На этой странице приведен каталог встроенных правил корреляции, которые используются прототипом SIEM-подсистемы ConShield.
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle app-table">
        <thead>
            <tr>
                <th>Код правила</th>
                <th>Название</th>
                <th>Критичность</th>
                <th>Условие</th>
                <th>Окно наблюдения</th>
                <th>Объект группировки</th>
                <th>Описание</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><code class="id-code">@item.RuleCode</code></td>
                <td>@DisplayText.RuleName(item.RuleCode, item.RuleName)</td>
                <td>
                    @switch (item.Severity)
                    {
                        case EventSeverity.Critical:
                            <span class="app-badge badge-danger-soft">Критический</span>
                            break;
                        case EventSeverity.High:
                            <span class="app-badge text-bg-primary">Высокий</span>
                            break;
                        case EventSeverity.Warning:
                            <span class="app-badge badge-attention">Предупреждение</span>
                            break;
                        default:
                            <span class="app-badge badge-neutral">Информационный</span>
                            break;
                    }
                </td>
                <td>@DisplayText.RuleCondition(item.RuleCode, item.ConditionText)</td>
                <td>@item.WindowText</td>
                <td>@DisplayText.RuleTriggerEntity(item.RuleCode, item.TriggerEntityText)</td>
                <td>@DisplayText.RuleDescription(item.RuleCode, item.Description)</td>
            </tr>
        }
        </tbody>
    </table>
</div>
