<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConShield</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @{
        string IsActive(string controller, string? action = null)
        {
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
            var actionMatches = action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
            return controllerMatches && actionMatches ? "active" : string.Empty;
        }
    }
    <header>
        <nav class="navbar navbar-expand-lg app-navbar mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">ConShield</a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="collapse navbar-collapse show">
                        <ul class="navbar-nav me-auto app-nav-list">
                            <li class="nav-item">
                                <a class="nav-link @IsActive("UserExceptions")" asp-controller="UserExceptions" asp-action="Index">Исключения доступа</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("SecurityEvents")" asp-controller="SecurityEvents" asp-action="Index">События</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Incidents")" asp-controller="Incidents" asp-action="Index">Инциденты</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Siem", "Index")" asp-controller="Siem" asp-action="Index">Оповещения SIEM</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Siem", "Rules")" asp-controller="Siem" asp-action="Rules">Правила SIEM</a>
                            </li>
                            @if (User.IsInRole("AdminIB"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Sensors")" asp-controller="Sensors" asp-action="Index">Сенсоры</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Operations", "Health")" asp-controller="Operations" asp-action="Health">Состояние</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Reports")" asp-controller="Reports" asp-action="SecuritySummary">Отчёты</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Outbox")" asp-controller="Outbox" asp-action="Index">Очередь</a>
                                </li>
                            }
                        </ul>

                        <div class="app-topbar-actions">
                            <button class="app-theme-toggle"
                                    type="button"
                                    data-theme-toggle
                                    aria-label="Переключить тему"
                                    aria-pressed="false">
                                <span aria-hidden="true">◐</span>
                                <span>Тема: <span data-theme-label>Светлая</span></span>
                            </button>

                            <span class="navbar-text">
                                @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                                (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)
                            </span>

                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button class="btn btn-outline-light btn-sm" type="submit">Выход</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
