@model SensorCredentialRotationResultViewModel

@{
    ViewData["Title"] = "Sensor credential rotated";
}

<h1>Sensor credential rotated</h1>

<div class="alert alert-warning">
    <strong>Shown once.</strong>
    Copy this credential directly to the protected Fedora environment. Do not paste it into chat,
    GitHub, logs, screenshots, tickets, shell history, or commits. Browser refresh can submit
    another rotation request.
</div>

<dl class="row">
    <dt class="col-sm-3">Sensor display name</dt>
    <dd class="col-sm-9">@Model.DisplayName</dd>

    <dt class="col-sm-3">Sensor ID</dt>
    <dd class="col-sm-9"><code>@Model.SensorId</code></dd>

    <dt class="col-sm-3">Source system</dt>
    <dd class="col-sm-9"><code>@Model.SourceSystem</code></dd>

    <dt class="col-sm-3">New Credential ID</dt>
    <dd class="col-sm-9"><code>@Model.CredentialId</code></dd>

    <dt class="col-sm-3">New plaintext credential</dt>
    <dd class="col-sm-9">
        <code class="user-select-all">@Model.OneTimeCredential</code>
    </dd>

    <dt class="col-sm-3">Rotated UTC</dt>
    <dd class="col-sm-9">@Model.RotatedAtUtc.ToString("u")</dd>
</dl>

<h2 class="h5">Fedora environment keys</h2>

<p>Update the protected RuntimeCollector environment manually with these key names:</p>

<ul>
    <li><code>CONSHIELD_SENSOR_ID</code></li>
    <li><code>CONSHIELD_SENSOR_CREDENTIAL_ID</code></li>
    <li><code>CONSHIELD_RUNTIME_COLLECTOR_API_KEY</code></li>
</ul>

<a asp-controller="Sensors" asp-action="Index" class="btn btn-primary">Back to Sensors</a>
