@model SensorRevocationFailureViewModel

@{
    ViewData["Title"] = "Revocation failed";
}

<h1>Revocation failed</h1>

<div class="alert alert-danger">
    @Model.Message
</div>

<dl class="row">
    <dt class="col-sm-3">Sensor ID</dt>
    <dd class="col-sm-9"><code>@Model.SensorId</code></dd>

    @if (Model.CredentialId is not null)
    {
        <dt class="col-sm-3">Credential ID</dt>
        <dd class="col-sm-9"><code>@Model.CredentialId</code></dd>
    }
</dl>

<a asp-controller="Sensors" asp-action="Details" asp-route-sensorId="@Model.SensorId" class="btn btn-primary">
    Back to sensor details
</a>
<a asp-controller="Sensors" asp-action="Index" class="btn btn-outline-secondary">Back to Sensors</a>
