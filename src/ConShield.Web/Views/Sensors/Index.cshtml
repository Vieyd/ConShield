@model SensorFleetIndexViewModel

@{
    ViewData["Title"] = "Сенсоры";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">Сенсоры</h1>
        <p class="text-muted mb-0">
            Read-only enrolled sensor inventory. Secrets and credential verifiers are never displayed.
        </p>
    </div>
    <div class="text-muted small">
        Generated UTC: @Model.GeneratedAtUtc.ToString("u")
    </div>
</div>

@if (Model.Sensors.Count == 0)
{
    <div class="alert alert-info">
        Enrolled sensors are not available yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Display name</th>
                    <th>Sensor ID</th>
                    <th>Source system</th>
                    <th>Last seen UTC</th>
                    <th>Heartbeat age</th>
                    <th>Credentials</th>
                    <th>Certificate</th>
                    <th>Created UTC</th>
                    <th>Updated UTC</th>
                    <th>Revoked UTC</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sensor in Model.Sensors)
                {
                    <tr>
                        <td>
                            <span class="badge @sensor.StatusCssClass">@sensor.Status</span>
                        </td>
                        <td>@sensor.DisplayName</td>
                        <td><code>@sensor.SensorId</code></td>
                        <td><code>@sensor.SourceSystem</code></td>
                        <td>@(sensor.LastSeenAtUtc?.ToString("u") ?? "—")</td>
                        <td>@sensor.HeartbeatAgeText</td>
                        <td>
                            <span class="badge bg-primary">@sensor.ActiveCredentialCount active</span>
                            <span class="text-muted small">/ @sensor.CredentialCount total</span>
                            @if (sensor.NewestCredentialCreatedAtUtc is not null)
                            {
                                <div class="text-muted small">
                                    newest: @sensor.NewestCredentialCreatedAtUtc.Value.ToString("u")
                                </div>
                            }
                        </td>
                        <td>
                            @if (sensor.HasCertificateFingerprint)
                            {
                                <span class="badge bg-success">present</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">not set</span>
                            }
                        </td>
                        <td>@sensor.CreatedAtUtc.ToString("u")</td>
                        <td>@sensor.UpdatedAtUtc.ToString("u")</td>
                        <td>@(sensor.RevokedAtUtc?.ToString("u") ?? "—")</td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <a asp-controller="Sensors"
                                   asp-action="Details"
                                   asp-route-sensorId="@sensor.SensorId"
                                   class="btn btn-sm btn-outline-primary">
                                    Детали
                                </a>
                            @if (sensor.CanRotateCredential)
                            {
                                <form asp-controller="Sensors"
                                      asp-action="RotateCredential"
                                      method="post"
                                      onsubmit="return confirm('Rotate this sensor credential? The new credential is shown once and must be copied directly to the protected Fedora environment.');">
                                    <input type="hidden" name="sensorId" value="@sensor.SensorId" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        Rotate credential
                                    </button>
                                </form>
                            }
                                @if (sensor.CanRevokeSensor)
                                {
                                    <form asp-controller="Sensors"
                                          asp-action="RevokeSensor"
                                          method="post"
                                          onsubmit="return confirm('Отозвать сенсор? Все credentials сенсора будут отозваны, а RuntimeCollector heartbeat/event ingestion перестанут приниматься.');">
                                        <input type="hidden" name="sensorId" value="@sensor.SensorId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Отозвать сенсор
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">not available</span>
                            }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
