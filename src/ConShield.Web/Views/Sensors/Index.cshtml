@model SensorFleetIndexViewModel

@{
    ViewData["Title"] = "Сенсоры";
}

<div class="app-page-header">
    <div>
        <h1 class="mb-1">Сенсоры</h1>
        <p class="text-muted mb-0">
            Реестр зарегистрированных сенсоров. Секреты и verifier-значения учетных данных не отображаются.
        </p>
    </div>
    <div class="text-muted small">
        Сформировано UTC: @Model.GeneratedAtUtc.ToString("u")
    </div>
</div>

@if (Model.Sensors.Count == 0)
{
    <div class="alert alert-info">
        Зарегистрированные сенсоры пока отсутствуют.
    </div>
}
else
{
    <div class="app-table-card">
        <div class="app-table-scroll-wrap" data-table-scroll-sync>
            <div class="app-table-scrollbar-top" aria-hidden="true">
                <div class="app-table-scrollbar-inner"></div>
            </div>
            <div class="app-table-scroll">
        <table class="table table-sm table-striped align-middle app-table app-table-wide">
            <thead>
                <tr>
                    <th>Статус</th>
                    <th>Имя</th>
                    <th>Sensor ID</th>
                    <th>Система-источник</th>
                    <th>Последняя активность UTC</th>
                    <th>Давность heartbeat</th>
                    <th>Учетные данные</th>
                    <th>Сертификат</th>
                    <th>Создано UTC</th>
                    <th>Обновлено UTC</th>
                    <th>Отозвано UTC</th>
                    <th class="app-table-actions-col">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sensor in Model.Sensors)
                {
                    <tr>
                        <td>
                            <span class="app-status @DisplayText.StatusClass(sensor.Status)">
                                <span class="app-status-dot" aria-hidden="true"></span>
                                <span>@DisplayText.Status(sensor.Status)</span>
                            </span>
                        </td>
                        <td>@sensor.DisplayName</td>
                        <td><code class="id-code app-code-short" title="@sensor.SensorId">@DisplayText.ShortTechnicalValue(sensor.SensorId)</code></td>
                        <td><code class="id-code app-code-short" title="@sensor.SourceSystem">@DisplayText.ShortTechnicalValue(sensor.SourceSystem)</code></td>
                        <td>@(sensor.LastSeenAtUtc?.ToString("u") ?? "—")</td>
                        <td>@sensor.HeartbeatAgeText</td>
                        <td>
                            <span class="app-status app-status-high">
                                <span class="app-status-dot" aria-hidden="true"></span>
                                <span>@sensor.ActiveCredentialCount активных</span>
                            </span>
                            <span class="text-muted small">/ всего @sensor.CredentialCount</span>
                            @if (sensor.NewestCredentialCreatedAtUtc is not null)
                            {
                                <div class="text-muted small">
                                    последняя: @sensor.NewestCredentialCreatedAtUtc.Value.ToString("u")
                                </div>
                            }
                        </td>
                        <td>
                            @if (sensor.HasCertificateFingerprint)
                            {
                                <span class="app-status app-status-ok"><span class="app-status-dot" aria-hidden="true"></span><span>Есть</span></span>
                            }
                            else
                            {
                                <span class="app-status app-status-neutral"><span class="app-status-dot" aria-hidden="true"></span><span>Не задан</span></span>
                            }
                        </td>
                        <td>@sensor.CreatedAtUtc.ToString("u")</td>
                        <td>@sensor.UpdatedAtUtc.ToString("u")</td>
                        <td>@(sensor.RevokedAtUtc?.ToString("u") ?? "—")</td>
                        <td class="app-table-actions-col">
                            <div class="app-action-group">
                                <a asp-controller="Sensors"
                                   asp-action="Details"
                                   asp-route-sensorId="@sensor.SensorId"
                                   class="btn btn-sm btn-outline-primary">
                                    Открыть
                                </a>
                                @if (sensor.CanRotateCredential)
                                {
                                    <form asp-controller="Sensors"
                                          asp-action="RotateCredential"
                                          method="post"
                                          onsubmit="return confirm('Ротировать учетные данные сенсора? Новый секрет будет показан один раз и должен быть сразу перенесен в защищенную Fedora-среду.');">
                                        <input type="hidden" name="sensorId" value="@sensor.SensorId" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">
                                            Ротировать
                                        </button>
                                    </form>
                                }
                                @if (sensor.CanRevokeSensor)
                                {
                                    <form asp-controller="Sensors"
                                          asp-action="RevokeSensor"
                                          method="post"
                                          onsubmit="return confirm('Отозвать сенсор? Все credentials сенсора будут отозваны, а RuntimeCollector heartbeat/event ingestion перестанут приниматься.');">
                                        <input type="hidden" name="sensorId" value="@sensor.SensorId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Отозвать сенсор
                                        </button>
                                    </form>
                                }
                                @if (!sensor.CanRotateCredential && !sensor.CanRevokeSensor)
                                {
                                    <span class="text-muted small">Недоступно</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
            </div>
        </div>
    </div>
}
