@model SensorCredentialRotationFailureViewModel

@{
    ViewData["Title"] = "Ротация учетных данных не выполнена";
}

<h1>Ротация учетных данных не выполнена</h1>

<div class="alert alert-danger">
    @Model.Message
</div>

<p class="text-muted">
    Новый секрет не был создан или показан. Sensor ID: <code>@Model.SensorId</code>
</p>

<a asp-controller="Sensors" asp-action="Index" class="btn btn-primary">К сенсорам</a>
