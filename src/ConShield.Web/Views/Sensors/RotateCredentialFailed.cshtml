@model SensorCredentialRotationFailureViewModel

@{
    ViewData["Title"] = "Sensor credential rotation failed";
}

<h1>Sensor credential rotation failed</h1>

<div class="alert alert-danger">
    @Model.Message
</div>

<p class="text-muted">
    No new credential was generated or displayed. Sensor ID: <code>@Model.SensorId</code>
</p>

<a asp-controller="Sensors" asp-action="Index" class="btn btn-primary">Back to Sensors</a>
