@model SensorDetailsViewModel

@{
    ViewData["Title"] = "Детали сенсора";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">Детали сенсора</h1>
        <p class="text-muted mb-0">
            Public lifecycle metadata only. Credential plaintext and secret validation material are never displayed.
        </p>
    </div>
    <a asp-controller="Sensors" asp-action="Index" class="btn btn-outline-secondary">Назад к сенсорам</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5">@Model.DisplayName</h2>
        <dl class="row mb-0">
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge @Model.StatusCssClass">@Model.Status</span></dd>

            <dt class="col-sm-3">Sensor ID</dt>
            <dd class="col-sm-9"><code>@Model.SensorId</code></dd>

            <dt class="col-sm-3">Source system</dt>
            <dd class="col-sm-9"><code>@Model.SourceSystem</code></dd>

            <dt class="col-sm-3">Last seen UTC</dt>
            <dd class="col-sm-9">@(Model.LastSeenAtUtc?.ToString("u") ?? "—")</dd>

            <dt class="col-sm-3">Heartbeat age</dt>
            <dd class="col-sm-9">@Model.HeartbeatAgeText</dd>

            <dt class="col-sm-3">Certificate</dt>
            <dd class="col-sm-9">@(Model.HasCertificateFingerprint ? "present" : "not set")</dd>

            <dt class="col-sm-3">Created UTC</dt>
            <dd class="col-sm-9">@Model.CreatedAtUtc.ToString("u")</dd>

            <dt class="col-sm-3">Updated UTC</dt>
            <dd class="col-sm-9">@Model.UpdatedAtUtc.ToString("u")</dd>

            <dt class="col-sm-3">Revoked UTC</dt>
            <dd class="col-sm-9">@(Model.RevokedAtUtc?.ToString("u") ?? "—")</dd>
        </dl>

        @if (Model.CanRevokeSensor)
        {
            <form asp-controller="Sensors"
                  asp-action="RevokeSensor"
                  method="post"
                  class="mt-3"
                  onsubmit="return confirm('Отозвать сенсор? Все credentials сенсора будут отозваны, а RuntimeCollector heartbeat/event ingestion перестанут приниматься.');">
                <input type="hidden" name="sensorId" value="@Model.SensorId" />
                <button type="submit" class="btn btn-danger">
                    Отозвать сенсор
                </button>
                <span class="text-muted ms-2">Все credentials сенсора будут отозваны.</span>
            </form>
        }
    </div>
</div>

<h2 class="h4">Credentials</h2>

@if (Model.Credentials.Count == 0)
{
    <div class="alert alert-info">Credentials are not available for this sensor.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Credential ID</th>
                    <th>Created UTC</th>
                    <th>Rotated UTC</th>
                    <th>Revoked UTC</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var credential in Model.Credentials)
                {
                    <tr>
                        <td><span class="badge @credential.StatusCssClass">@credential.Status</span></td>
                        <td><code>@credential.CredentialId</code></td>
                        <td>@credential.CreatedAtUtc.ToString("u")</td>
                        <td>@(credential.RotatedAtUtc?.ToString("u") ?? "—")</td>
                        <td>@(credential.RevokedAtUtc?.ToString("u") ?? "—")</td>
                        <td>
                            @if (credential.CanRevokeCredential)
                            {
                                <form asp-controller="Sensors"
                                      asp-action="RevokeCredential"
                                      method="post"
                                      onsubmit="return confirm('Отозвать credential? RuntimeCollector перестанет принимать этот credential.');">
                                    <input type="hidden" name="sensorId" value="@Model.SensorId" />
                                    <input type="hidden" name="credentialId" value="@credential.CredentialId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Отозвать credential
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">not available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
