@model SensorDetailsViewModel

@{
    ViewData["Title"] = "Детали сенсора";
}

<div class="app-page-header">
    <div>
        <h1 class="mb-1">Детали сенсора</h1>
        <p class="text-muted mb-0">
            Отображаются только публичные lifecycle-метаданные. Plaintext credential и secret validation material никогда не выводятся.
        </p>
    </div>
    <a asp-controller="Sensors" asp-action="Index" class="btn btn-outline-secondary">Назад к сенсорам</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5">@Model.DisplayName</h2>
        <dl class="row mb-0">
            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">
                <span class="app-status @DisplayText.StatusClass(Model.Status)">
                    <span class="app-status-dot" aria-hidden="true"></span>
                    <span>@DisplayText.Status(Model.Status)</span>
                </span>
            </dd>

            <dt class="col-sm-3">Sensor ID</dt>
            <dd class="col-sm-9"><code>@Model.SensorId</code></dd>

            <dt class="col-sm-3">Система-источник</dt>
            <dd class="col-sm-9"><code>@Model.SourceSystem</code></dd>

            <dt class="col-sm-3">Последняя активность UTC</dt>
            <dd class="col-sm-9">@(Model.LastSeenAtUtc?.ToString("u") ?? "—")</dd>

            <dt class="col-sm-3">Давность heartbeat</dt>
            <dd class="col-sm-9">@Model.HeartbeatAgeText</dd>

            <dt class="col-sm-3">Сертификат</dt>
            <dd class="col-sm-9">@(Model.HasCertificateFingerprint ? "Есть" : "Не задан")</dd>

            <dt class="col-sm-3">Создано UTC</dt>
            <dd class="col-sm-9">@Model.CreatedAtUtc.ToString("u")</dd>

            <dt class="col-sm-3">Обновлено UTC</dt>
            <dd class="col-sm-9">@Model.UpdatedAtUtc.ToString("u")</dd>

            <dt class="col-sm-3">Отозвано UTC</dt>
            <dd class="col-sm-9">@(Model.RevokedAtUtc?.ToString("u") ?? "—")</dd>
        </dl>

        @if (Model.CanRevokeSensor)
        {
            <form asp-controller="Sensors"
                  asp-action="RevokeSensor"
                  method="post"
                  class="mt-3"
                  onsubmit="return confirm('Отозвать сенсор? Все credentials сенсора будут отозваны, а RuntimeCollector heartbeat/event ingestion перестанут приниматься.');">
                <input type="hidden" name="sensorId" value="@Model.SensorId" />
                <button type="submit" class="btn btn-danger">
                    Отозвать сенсор
                </button>
                <span class="text-muted ms-2">Все credentials сенсора будут отозваны.</span>
            </form>
        }
    </div>
</div>

<h2 class="h4">Учетные данные</h2>

@if (Model.Credentials.Count == 0)
{
    <div class="alert alert-info">Учетные данные для этого сенсора недоступны.</div>
}
else
{
    <div class="app-table-card">
        <div class="app-table-scroll-wrap" data-table-scroll-sync>
            <div class="app-table-scrollbar-top" aria-hidden="true">
                <div class="app-table-scrollbar-inner"></div>
            </div>
            <div class="app-table-scroll">
        <table class="table table-sm table-striped align-middle app-table">
            <thead>
                <tr>
                    <th>Статус</th>
                    <th>Credential ID</th>
                    <th>Создано UTC</th>
                    <th>Ротировано UTC</th>
                    <th>Отозвано UTC</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var credential in Model.Credentials)
                {
                    <tr>
                        <td>
                            <span class="app-status @DisplayText.StatusClass(credential.Status)">
                                <span class="app-status-dot" aria-hidden="true"></span>
                                <span>@DisplayText.Status(credential.Status)</span>
                            </span>
                        </td>
                        <td><code>@credential.CredentialId</code></td>
                        <td>@credential.CreatedAtUtc.ToString("u")</td>
                        <td>@(credential.RotatedAtUtc?.ToString("u") ?? "—")</td>
                        <td>@(credential.RevokedAtUtc?.ToString("u") ?? "—")</td>
                        <td>
                            @if (credential.CanRevokeCredential)
                            {
                                <form asp-controller="Sensors"
                                      asp-action="RevokeCredential"
                                      method="post"
                                      onsubmit="return confirm('Отозвать credential? RuntimeCollector перестанет принимать этот credential.');">
                                    <input type="hidden" name="sensorId" value="@Model.SensorId" />
                                    <input type="hidden" name="credentialId" value="@credential.CredentialId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Отозвать credential
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Недоступно</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
            </div>
        </div>
    </div>
}
