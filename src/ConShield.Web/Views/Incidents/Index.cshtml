@using ConShield.Contracts.Constants
@using ConShield.Contracts.Enums
@using ConShield.Web.Infrastructure
@model ConShield.Web.ViewModels.IncidentIndexViewModel
@{
    ViewData["Title"] = "Инциденты";
}

<div class="app-page-header">
    <h2 class="mb-0">Инциденты</h2>
    @if (User.IsInRole(AppRoles.AdminIB))
    {
        <a asp-action="Create" class="btn btn-primary">Создать инцидент</a>
    }
</div>

<form method="get" class="app-filter-panel row g-2 mb-4">
    <div class="col-md-4">
        <input name="SearchText" value="@Model.Filter.SearchText" class="form-control" placeholder="Поиск по названию, примечанию или ID события-источника" />
    </div>
    <div class="col-md-3">
        <select name="Severity" class="form-select">
            <option value="">Все уровни</option>
            @foreach (EventSeverity severity in Enum.GetValues<EventSeverity>())
            {
                if (Model.Filter.Severity == severity)
                {
                    <option value="@severity" selected>@DisplayText.Severity(severity)</option>
                }
                else
                {
                    <option value="@severity">@DisplayText.Severity(severity)</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="Status" class="form-select">
            <option value="">Все статусы</option>
            @if (Model.Filter.Status == IncidentStatuses.New)
            {
                <option value="@IncidentStatuses.New" selected>Новый</option>
            }
            else
            {
                <option value="@IncidentStatuses.New">Новый</option>
            }
            @if (Model.Filter.Status == IncidentStatuses.InProgress)
            {
                <option value="@IncidentStatuses.InProgress" selected>В работе</option>
            }
            else
            {
                <option value="@IncidentStatuses.InProgress">В работе</option>
            }
            @if (Model.Filter.Status == IncidentStatuses.Closed)
            {
                <option value="@IncidentStatuses.Closed" selected>Закрыто</option>
            }
            else
            {
                <option value="@IncidentStatuses.Closed">Закрыто</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-light">Применить</button>
    </div>
</form>

<div class="app-table-card">
    <div class="app-table-scroll-wrap" data-table-scroll-sync>
        <div class="app-table-scrollbar-top" aria-hidden="true">
            <div class="app-table-scrollbar-inner"></div>
        </div>
        <div class="app-table-scroll">
            <table class="table table-striped align-middle app-table">
            <thead>
            <tr>
                <th class="app-table-id-col-sm">ID</th>
                <th>Создан</th>
                <th>Название</th>
                <th>Критичность</th>
                <th>Статус</th>
                <th class="app-table-id-col">Событие-источник</th>
                <th>Действия</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="app-table-id-col-sm"><code class="app-id-pill">@item.Id</code></td>
                    <td>@item.CreatedAtUtc.ToMoscowDisplay()</td>
                    <td>@DisplayText.IncidentTitle(item.Name)</td>
                    <td>
                        <span class="app-status @DisplayText.SeverityClass(item.Severity)">
                            <span class="app-status-dot" aria-hidden="true"></span>
                            <span>@DisplayText.Severity(item.Severity)</span>
                        </span>
                    </td>
                    <td>
                        <span class="app-status @DisplayText.StatusClass(item.Status)">
                            <span class="app-status-dot" aria-hidden="true"></span>
                            <span>@DisplayText.Status(item.Status)</span>
                        </span>
                    </td>
                    <td class="app-table-id-col">
                        @if (item.SourceEventId.HasValue)
                        {
                            <a asp-controller="SecurityEvents"
                               asp-action="Index"
                               asp-route-SearchText="@item.SourceEventId.Value"
                               class="app-id-pill app-id-nowrap"
                               title="Открыть событие безопасности @item.SourceEventId.Value">@item.SourceEventId.Value</a>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td>
                        <div class="app-action-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Открыть</a>
                            @if (User.IsInRole(AppRoles.AdminIB))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                                if (item.Status != IncidentStatuses.InProgress && item.Status != IncidentStatuses.Closed)
                                {
                                    <form asp-action="ChangeStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="status" value="@IncidentStatuses.InProgress" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">В работу</button>
                                    </form>
                                }
                                if (item.Status != IncidentStatuses.Closed)
                                {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Закрыть с выводом</a>
                                }
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_Pagination" model="Model.Paging" />
