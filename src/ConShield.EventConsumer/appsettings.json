{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "SecurityEventOutbox": {
    "Transport": "Jsonl"
  },
  "RabbitMq": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/conshield",
    "UserName": "",
    "Password": "",
    "ExchangeName": "conshield.security.events.v1",
    "RoutingKey": "security.event.created",
    "QueueName": "conshield.security-events.consumer.v1",
    "DeadLetterExchangeName": "conshield.security.events.dlx.v1",
    "DeadLetterRoutingKey": "security.event.dead",
    "DeadLetterQueueName": "conshield.security-events.dead.v1",
    "PrefetchCount": 20,
    "ConnectionTimeoutSeconds": 10,
    "PublishTimeoutSeconds": 10,
    "ConsumerShutdownTimeoutSeconds": 10,
    "UseTls": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
